# Diese Datei zu .env kopieren und Werte eintragen.
# .env wird NICHT committet (siehe .gitignore).

# Geheimer Schlüssel für Sessions/CSRF (beliebiger langer Zufallsstring).
SECRET_KEY=change-me-to-a-long-random-string

# Optional: Supabase/Postgres Connection String (URI).
# Wenn leer gelassen, nutzt die App automatisch eine lokale SQLite-Datei (flatemate.db).
# Beispiel Supabase:
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=
