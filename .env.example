# Diese Datei zu .env kopieren und Werte eintragen.
# .env wird NICHT committet (siehe .gitignore).

# Geheimer Schlüssel für Sessions/CSRF (beliebiger langer Zufallsstring).
SECRET_KEY=change-me-to-a-long-random-string

# Optional: Supabase/Postgres Connection String (URI).
# Wenn leer gelassen, nutzt die App automatisch eine lokale SQLite-Datei (flatmate.db).
# Supabase: Project Settings → Database → Connection string → "Session pooler" (Port 5432).
# [YOUR-PASSWORD] durch das DB-Passwort ersetzen.
# DATABASE_URL=postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Optional: Google Maps Embed API key fuer die Karte auf Inserat-Detailseiten.
GOOGLE_MAPS_API_KEY=

# Optional: Supabase Storage fuer dauerhafte Listing-Fotos.
# Bucket in Supabase Storage erstellen, z. B. "listing-photos", und public machen.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_STORAGE_BUCKET=listing-photos
# Empfohlen lokal/Render: Service Role Key nur als Env-Var setzen, nie committen.
# Alternativ funktioniert ein Anon Key nur, wenn die Storage Policies Uploads erlauben.
SUPABASE_STORAGE_KEY=

# E-Mail-Versand via SendGrid (https://sendgrid.com) — HTTP-API, kein SMTP.
# Single Sender Verification: EINE Absender-Adresse per Bestätigungslink verifizieren
# (keine eigene Domain nötig), danach Versand an beliebige Empfänger möglich.
# Leer lassen = E-Mails werden lokal nur ins Log geschrieben (kein echter Versand).
SENDGRID_API_KEY=
# Die in SendGrid verifizierte Absender-Adresse (z. B. dein Gmail):
MAIL_FROM=
MAIL_FROM_NAME=FlatMate
