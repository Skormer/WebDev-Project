# Diese Datei zu .env kopieren und Werte eintragen.
# .env wird NICHT committet (siehe .gitignore).

# Geheimer Schlüssel für Sessions/CSRF (beliebiger langer Zufallsstring).
SECRET_KEY=change-me-to-a-long-random-string

# Optional: Supabase/Postgres Connection String (URI).
# Wenn leer gelassen, nutzt die App automatisch eine lokale SQLite-Datei (flatemate.db).
# Beispiel Supabase:
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=

# E-Mail-Versand via SendGrid (https://sendgrid.com) — HTTP-API, kein SMTP.
# Single Sender Verification: EINE Absender-Adresse per Bestätigungslink verifizieren
# (keine eigene Domain nötig), danach Versand an beliebige Empfänger möglich.
# Leer lassen = E-Mails werden lokal nur ins Log geschrieben (kein echter Versand).
SENDGRID_API_KEY=
# Die in SendGrid verifizierte Absender-Adresse (z. B. dein Gmail):
MAIL_FROM=
MAIL_FROM_NAME=FlateMate
